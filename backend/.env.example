# Environment Variables
# Copy this file to .env and update with your values

# Application
DEBUG=true
APP_ENV=development
BASE_URL=http://localhost:8000

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=apiweave

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Secrets
SECRET_KEY=change-me-in-production-use-a-strong-random-key
# DEPRECATED: APIWEAVE_ADMIN_KEY will be removed in Task 12 migration
APIWEAVE_ADMIN_KEY=
# Required in production for session signing
SESSION_SECRET_KEY=

# OAuth providers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Session / auth security
SESSION_MAX_IDLE_MINUTES=720
SESSION_MAX_ABSOLUTE_MINUTES=10080
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax
CSRF_ENABLED=true
WEBHOOK_REQUIRE_HMAC=false
APPROVED_DOMAINS_ENABLED=false
APPROVED_DOMAINS=
SETUP_MODE_ENABLED=true

# Worker
WORKER_POLL_INTERVAL=5
WORKER_MAX_RETRIES=3

# Artifacts
ARTIFACTS_PATH=./artifacts
