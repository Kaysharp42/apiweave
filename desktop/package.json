{
  "name": "apiweave-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron shell for the APIWeave desktop app",
  "author": "Kaysharp42 <kaysharp42@users.noreply.github.com>",
  "homepage": "https://github.com/Kaysharp42/apiweave",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.kaysharp.apiweave",
    "productName": "APIWeave",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": ["electron/**/*"],
    "extraResources": [
      { "from": "../frontend/dist", "to": "frontend" },
      { "from": "resources/sidecars", "to": "sidecars" }
    ],
    "win": { "target": ["nsis"] },
    "linux": { "target": ["AppImage", "deb", "pacman"], "category": "Development" },
    "mac": { "target": ["dmg"] }
  }
}
