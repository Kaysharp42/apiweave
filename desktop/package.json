{
  "name": "apiweave-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron shell for the APIWeave desktop app",
  "author": "Kaysharp42 <kaysharp42@users.noreply.github.com>",
  "homepage": "https://github.com/Kaysharp42/apiweave",
  "main": "dist/desktop/main.js",
  "scripts": {
    "dev": "npm run dev:electron",
    "prestart": "npm run rebuild:electron",
    "start": "electron .",
    "build": "electron-builder",
    "parity": "node core/runner/harness/run-parity.mjs",
    "parity:capture": "node core/runner/harness/run-parity.mjs --capture",
    "predev:electron": "npm run rebuild:electron",
    "dev:electron": "npm --prefix ../frontend run build && npm run build:electron && electron .",
    "build:electron": "node esbuild.config.cjs",
    "typecheck:desktop": "tsc --noEmit",
    "rebuild:electron": "node scripts/rebuild-sqlite.mjs electron",
    "rebuild:node": "node scripts/rebuild-sqlite.mjs node",
    "pretest:desktop": "npm run rebuild:node",
    "test:desktop": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.1",
    "@modelcontextprotocol/sdk": "^1.23.0",
    "better-sqlite3": "^12.6.0",
    "jose": "6.2.3",
    "libsodium-wrappers": "^0.8.4",
    "undici": "^7.16.0",
    "yaml": "^2.9.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@apiweave/proto": "https://github.com/Kaysharp42/apiweave-proto/archive/refs/tags/v0.1.0.tar.gz",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.27.2",
    "nock": "^14.0.16",
    "typescript": "^6.0.3",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.kaysharp.apiweave",
    "productName": "APIWeave",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/desktop/**/*"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend"
      }
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "pacman"
      ],
      "category": "Development"
    },
    "mac": {
      "target": [
        "dmg"
      ]
    }
  }
}
