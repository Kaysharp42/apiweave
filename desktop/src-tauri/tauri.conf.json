{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "apiweave-desktop",
  "version": "0.1.0",
  "identifier": "com.kaysharp.apiweave",
  "build": {
    "frontendDist": "../../frontend/dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "cd ../frontend && npx vite",
    "beforeBuildCommand": "npm --prefix ../frontend run build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/apiweave-backend",
      "binaries/apiweave-worker",
      "binaries/mongod"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
