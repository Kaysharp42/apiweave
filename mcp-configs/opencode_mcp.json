{
  "mcp": {
    "apiweave-stdio": {
      "type": "stdio",
      "command": "python",
      "args": ["mcp_stdio.py"],
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "MCP_ENABLED": "true",
        "MCP_HTTP_ENABLED": "false"
      }
    },
    "apiweave-http": {
      "type": "http",
      "url": "http://localhost:8000/mcp",
      "headers": {
        "Authorization": "Bearer YOUR_MCP_API_KEY"
      }
    },
    "codebase-memory-mcp": {
      "type": "local",
      "command": [
        "codebase-memory-mcp"
      ]
    }
  }
}
